# FASAL backend configuration (copy to .env). All vars are prefixed FASAL_.
# This phase keeps DB/storage light; defaults are local filesystem / SQLite.

FASAL_ENV=dev
FASAL_DATA_DIR=./.data
FASAL_ARTIFACTS_DIR=./.artifacts

# Light data layer (repository/storage are intentionally minimal this phase).
# Swap to Postgres/PostGIS + S3/MinIO later via these vars (see docs/02-system-architecture.md).
FASAL_DATABASE_URL=sqlite:///./.data/fasal.db
FASAL_OBJECT_STORE_PATH=./.data/objects

# Optional MLOps (extras: pip install "fasal[mlops]")
# FASAL_MLFLOW_TRACKING_URI=http://localhost:5000

FASAL_RANDOM_SEED=1337
