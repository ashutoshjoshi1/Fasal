# FASAL console (Next.js) — copy to .env.local
# Base URL of the FastAPI backend (run: uvicorn fasal.api.app:app --reload).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional MapLibre style URL. If unset, a built-in minimal raster style is used (no API key).
# NEXT_PUBLIC_MAP_STYLE=https://your-style.json
