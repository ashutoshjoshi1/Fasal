# FASAL backend configuration (copy to .env). All vars are prefixed FASAL_.
# This phase keeps DB/storage light; defaults are local filesystem / SQLite.

FASAL_ENV=dev
FASAL_DATA_DIR=./.data
FASAL_ARTIFACTS_DIR=./.artifacts

# Light data layer (repository/storage are intentionally minimal this phase).
# Swap to Postgres/PostGIS + S3/MinIO later via these vars (see docs/02-system-architecture.md).
FASAL_DATABASE_URL=sqlite:///./.data/fasal.db
FASAL_OBJECT_STORE_PATH=./.data/objects

# Optional MLOps (extras: pip install "fasal[mlops]")
# FASAL_MLFLOW_TRACKING_URI=http://localhost:5000

FASAL_RANDOM_SEED=1337

# Spectrometer — Avantes (AvaSpec) point sensor. Raw data is counts vs detector pixel.
# Supply YOUR device's values (from AvaSoft / the device file / AVS_GetLambda).
FASAL_SPECTROMETER_PIXELS=2048
FASAL_SPECTROMETER_WAVELENGTH_MIN_NM=200
FASAL_SPECTROMETER_WAVELENGTH_MAX_NM=1100
FASAL_DEFAULT_INTEGRATION_TIME_MS=50
# FASAL_DEFAULT_FILTER=OG515
FASAL_FOV_DEG=25
# Ascending pixel->wavelength polynomial (JSON list). None → linear placeholder over the range.
# FASAL_WAVELENGTH_COEFFICIENTS=[200.0, 0.44, 0.0, 0.0]

# --- API security (fasal.api) ---
# Auth is OPEN in dev when FASAL_API_KEYS is unset. To require an X-API-Key header, list
# "key:role" pairs (roles: admin/exporter/lab/...). admin is allowed everywhere; POST /lab-queue
# additionally accepts exporter/lab. /health and /models stay public.
# FASAL_API_KEYS=dev-admin-key:admin,exporter-key:exporter,lab-key:lab
FASAL_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FASAL_RATE_LIMIT_ENABLED=true
FASAL_RATE_LIMIT_PER_MINUTE=120
